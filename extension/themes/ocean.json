  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#546E7A", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#C3E88D" }
    },
    {
      "name": "String interpolation",
      "scope": ["string.template", "punctuation.definition.template-expression"],
      "settings": { "foreground": "#C3E88D" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#F78C6C" }
    },
    {
      "name": "Boolean",
      "scope": ["constant.language.boolean"],
      "settings": { "foreground": "#FF5370" }
    },
    {
      "name": "Null / Undefined",
      "scope": ["constant.language.null", "constant.language.undefined"],
      "settings": { "foreground": "#FF5370" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "keyword.control", "keyword.operator.new"],
      "settings": { "foreground": "#C792EA", "fontStyle": "italic" }
    },
    {
      "name": "Storage",
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#C792EA", "fontStyle": "italic" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#EEFFFF" }
    },
    {
      "name": "Variable parameter",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#F78C6C", "fontStyle": "italic" }
    },
    {
      "name": "Variable language",
      "scope": ["variable.language"],
      "settings": { "foreground": "#FF5370", "fontStyle": "italic" }
    },
    {
      "name": "Function name",
      "scope": ["entity.name.function", "meta.function-call.generic"],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "Class name",
      "scope": ["entity.name.class", "entity.name.type.class"],
      "settings": { "foreground": "#FFCB6B" }
    },
    {
      "name": "Inherited class",
      "scope": ["entity.other.inherited-class"],
      "settings": { "foreground": "#C3E88D", "fontStyle": "italic" }
    },
    {
      "name": "Type",
      "scope": ["entity.name.type", "support.type"],
      "settings": { "foreground": "#FFCB6B" }
    },
    {
      "name": "Constant",
      "scope": ["constant", "constant.other", "variable.other.constant"],
      "settings": { "foreground": "#F78C6C" }
    },
    {
      "name": "Tag",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#FF5370" }
    },
    {
      "name": "Attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#C792EA", "fontStyle": "italic" }
    },
    {
      "name": "CSS property",
      "scope": ["support.type.property-name"],
      "settings": { "foreground": "#80CBC4" }
    },
    {
      "name": "CSS value",
      "scope": ["support.constant.property-value"],
      "settings": { "foreground": "#C3E88D" }
    },
    {
      "name": "CSS unit",
      "scope": ["keyword.other.unit"],
      "settings": { "foreground": "#F78C6C" }
    },
    {
      "name": "CSS selector",
      "scope": ["entity.other.attribute-name.class.css"],
      "settings": { "foreground": "#FFCB6B" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "name": "Import / Module",
      "scope": ["keyword.control.import", "keyword.control.from"],
      "settings": { "foreground": "#C792EA", "fontStyle": "italic" }
    },
    {
      "name": "Support function",
      "scope": ["support.function"],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "Support class",
      "scope": ["support.class"],
      "settings": { "foreground": "#FFCB6B" }
    },
    {
      "name": "Decorator / Annotation",
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": { "foreground": "#F78C6C", "fontStyle": "italic" }
    },
    {
      "name": "JSON key",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#80CBC4" }
    },
    {
      "name": "Markdown heading",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#80CBC4", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#FFCB6B", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#C792EA", "fontStyle": "italic" }
    },
    {
      "name": "Markdown link",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#C3E88D" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": { "foreground": "#FF5370", "fontStyle": "italic underline" }
    }
  ]
}
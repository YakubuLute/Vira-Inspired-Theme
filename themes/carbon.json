  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#4A4A4A", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#89A87A" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#CF9E7A" }
    },
    {
      "name": "Boolean / Null",
      "scope": ["constant.language"],
      "settings": { "foreground": "#D47E7E" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "keyword.control"],
      "settings": { "foreground": "#B87AA8", "fontStyle": "italic" }
    },
    {
      "name": "Storage",
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#B87AA8", "fontStyle": "italic" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#D4D4D4" }
    },
    {
      "name": "Variable parameter",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#CF9E7A", "fontStyle": "italic" }
    },
    {
      "name": "Variable language",
      "scope": ["variable.language"],
      "settings": { "foreground": "#D47E7E", "fontStyle": "italic" }
    },
    {
      "name": "Function",
      "scope": ["entity.name.function"],
      "settings": { "foreground": "#7A8FA6" }
    },
    {
      "name": "Class",
      "scope": ["entity.name.class", "entity.name.type.class"],
      "settings": { "foreground": "#C9B87A" }
    },
    {
      "name": "Type",
      "scope": ["entity.name.type", "support.type"],
      "settings": { "foreground": "#C9B87A" }
    },
    {
      "name": "Constant",
      "scope": ["constant", "variable.other.constant"],
      "settings": { "foreground": "#CF9E7A" }
    },
    {
      "name": "Tag",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#D47E7E" }
    },
    {
      "name": "Attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#B87AA8", "fontStyle": "italic" }
    },
    {
      "name": "CSS property",
      "scope": ["support.type.property-name"],
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#A9B8C3" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#A9B8C3" }
    },
    {
      "name": "Support function",
      "scope": ["support.function"],
      "settings": { "foreground": "#7A8FA6" }
    },
    {
      "name": "Decorator",
      "scope": ["meta.decorator"],
      "settings": { "foreground": "#CF9E7A", "fontStyle": "italic" }
    },
    {
      "name": "JSON key",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "name": "Markdown heading",
      "scope": ["markup.heading"],
      "settings": { "foreground": "#89DDFF", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#C9B87A", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#B87AA8", "fontStyle": "italic" }
    },
    {
      "name": "Markdown link",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#7A8FA6" }
    }
  ]
}
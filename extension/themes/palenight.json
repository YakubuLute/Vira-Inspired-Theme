  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#676E95", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#C3E88D" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#F78C6C" }
    },
    {
      "name": "Boolean / Null",
      "scope": ["constant.language"],
      "settings": { "foreground": "#FF5370" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "keyword.control"],
      "settings": { "foreground": "#C792EA", "fontStyle": "italic" }
    },
    {
      "name": "Storage",
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#C792EA", "fontStyle": "italic" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#EEFFFF" }
    },
    {
      "name": "Variable parameter",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#F78C6C", "fontStyle": "italic" }
    },
    {
      "name": "Variable language",
      "scope": ["variable.language"],
      "settings": { "foreground": "#FF5370", "fontStyle": "italic" }
    },
    {
      "name": "Function",
      "scope": ["entity.name.function"],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "Class",
      "scope": ["entity.name.class", "entity.name.type.class"],
      "settings": { "foreground": "#FFCB6B" }
    },
    {
      "name": "Type",
      "scope": ["entity.name.type", "support.type"],
      "settings": { "foreground": "#FFCB6B" }
    },
    {
      "name": "Constant",
      "scope": ["constant", "variable.other.constant"],
      "settings": { "foreground": "#F78C6C" }
    },
    {
      "name": "Tag",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#FF5370" }
    },
    {
      "name": "Attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#C792EA", "fontStyle": "italic" }
    },
    {
      "name": "CSS property",
      "scope": ["support.type.property-name"],
      "settings": { "foreground": "#80CBC4" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "name": "Support function",
      "scope": ["support.function"],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "Decorator",
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": { "foreground": "#F78C6C", "fontStyle": "italic" }
    },
    {
      "name": "JSON key",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#80CBC4" }
    },
    {
      "name": "Markdown heading",
      "scope": ["markup.heading"],
      "settings": { "foreground": "#C792EA", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#FFCB6B", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#C792EA", "fontStyle": "italic" }
    },
    {
      "name": "Markdown link",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#82AAFF" }
    }
  ]
}